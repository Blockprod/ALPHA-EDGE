# ============================================================
# PROJECT      : ALPHAEDGE — FCR Forex Trading Bot
# FILE         : .pylintrc
# DESCRIPTION  : Pylint configuration — minimum score 8.5/10
# AUTHOR       : ALPHAEDGE Dev Team
# WORKFLOW     : VSCode + Claude + Copilot Pro + File Engineering
# PYTHON       : 3.11.9
# LAST UPDATED : 2026-03-07
# ============================================================

[MAIN]
py-version = 3.11
fail-under = 8.5
jobs = 1
load-plugins =
    pylint.extensions.docparams,
    pylint.extensions.typing
ignore = .venv,build,dist
ignore-patterns = .*\.pyx$,.*\.pxd$

[MESSAGES CONTROL]
# C0114: missing-module-docstring — handled by File Engineering header
# R0903: too-few-public-methods — needed for data classes / config objects
disable =
    C0114,
    R0903

[FORMAT]
max-line-length = 88
max-module-lines = 1000

[BASIC]
good-names = i,j,k,v,e,f,sl,tp,rr,df,dt,ib

[DESIGN]
max-args = 10
max-locals = 20
max-returns = 6
max-branches = 15
max-statements = 50

[IMPORTS]
known-third-party =
    ib_insync,
    loguru,
    rich,
    yaml,
    dotenv,
    vectorbt,
    numpy,
    pandas,
    matplotlib,
    pytest

[TYPECHECK]
ignored-modules = alphaedge.core
generated-members = numpy.*,pandas.*
