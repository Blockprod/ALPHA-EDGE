# --- IB Gateway Connection ---
# Your IB account ID
ALPHAEDGE_IB_ACCOUNT=DU1234567

# IB Gateway host (usually localhost)
ALPHAEDGE_IB_HOST=127.0.0.1

# IB Gateway port: 4001 = live, 4002 = paper
ALPHAEDGE_IB_PORT=4002

# IB client ID (unique per connection — EDGECORE uses 1, AlphaEdge uses 2)
ALPHAEDGE_IB_CLIENT_ID=2

# --- Trading Mode ---
# Paper trading mode: true (default) or false
# ⚠️ WARNING: Setting to "false" enables LIVE TRADING with real money!
ALPHAEDGE_PAPER=true
