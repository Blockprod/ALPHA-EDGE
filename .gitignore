# ============================================================
# PROJECT      : ALPHAEDGE — FCR Forex Trading Bot
# FILE         : .gitignore
# DESCRIPTION  : Git ignore rules for ALPHAEDGE project
# AUTHOR       : ALPHAEDGE Dev Team
# ============================================================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd

# --- Virtual Environment ---
.venv/
venv/
ENV/

# --- Cython Build ---
build/
dist/
*.egg-info/
*.c
!alphaedge/core/*.pyx

# --- IDE ---
.vscode/.ropeproject/
*.swp
*.swo

# --- Environment ---
.env

# --- Logs ---
alphaedge/logs/*.log

# --- Bar cache (avoid committing large IB data files) ---
alphaedge/cache/

# --- Runtime State ---
alphaedge_daily_state.json
*.tmp

# --- Proprietary / Sensitive ---
ALPHAEDGE_ACTION_PLAN.md

# --- QA Debug Dumps ---
mypy_errors*.txt
pylint_out*.txt
pylint_output*.txt
ruff_output*.txt

# --- Output Files ---
ALPHAEDGE_backtest_results.csv
ALPHAEDGE_equity_curve.png
ALPHAEDGE_coverage_report*/
ALPHAEDGE_coverage_report.html
htmlcov/
.coverage

# --- OS ---
Thumbs.db
.DS_Store
