# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd

# --- Virtual Environment ---
.venv/
venv/
ENV/

# --- Cython Build ---
build/
dist/
*.egg-info/
*.c
!alphaedge/core/*.pyx

# --- IDE ---
.vscode/.ropeproject/
*.swp
*.swo

# --- Environment ---
.env

# --- Logs ---
alphaedge/logs/*.log

# --- Proprietary / Sensitive ---
ALPHAEDGE_ACTION_PLAN.md

# --- Output Files ---
ALPHAEDGE_backtest_results.csv
ALPHAEDGE_equity_curve.png
ALPHAEDGE_coverage_report*/
ALPHAEDGE_coverage_report.html
htmlcov/
.coverage

# --- OS ---
Thumbs.db
.DS_Store
