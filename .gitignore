# ============================================================
# PROJECT      : ALPHAEDGE — FCR Forex Trading Bot
# FILE         : .gitignore
# DESCRIPTION  : Git ignore rules for ALPHAEDGE project
# AUTHOR       : ALPHAEDGE Dev Team
# ============================================================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd

# --- Virtual Environment ---
.venv/
venv/
ENV/

# --- Cython Build ---
build/
dist/
*.egg-info/
*.c
!alphaedge/core/*.pyx

# --- IDE ---
.vscode/.ropeproject/
*.swp
*.swo

# --- Environment ---
.env

# --- Logs ---
alphaedge/logs/*.log
alphaedge/logs/*.txt
backtest_run.log

# --- Sweep outputs ---
scripts/sweep_*.txt
scripts/targeted_sweep.txt
docs/ALPHAEDGE_ACTION_PLAN.md

# --- Bar cache (avoid committing large IB data files) ---
alphaedge/cache/

# --- Runtime State ---
alphaedge_daily_state.json
*.tmp

# --- Proprietary / Sensitive ---
ALPHAEDGE_ACTION_PLAN.md

# --- QA Debug Dumps ---
mypy_errors*.txt
pylint_out*.txt
pylint_output*.txt
ruff_output*.txt

# --- Output Files ---
reports/ALPHAEDGE_backtest_results.csv
reports/ALPHAEDGE_equity_curve.png
reports/ALPHAEDGE_coverage_report*/
reports/ALPHAEDGE_coverage_report.html
htmlcov/
reports/backtest_result.txt
reports/backtest_run.log
.coverage

# --- OS ---
Thumbs.db
.DS_Store
